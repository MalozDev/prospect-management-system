# MongoDB connection string
# For local MongoDB: mongodb://localhost:27017/prospect-management
# For MongoDB Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/prospect-management
MONGODB_URI=mongodb+srv://user:password@cluster0.mongodb.net/prospect-management?retryWrites=true&w=majority

# JWT secret key for signing auth tokens
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=change-this-to-a-random-secret-in-production
